# ====== ИИ-Редакция — переменные окружения ======
# Скопируйте этот файл в .env и заполните реальными ключами.
# .env НЕ коммитить в git (добавьте его в .gitignore).

# --- OpenAI (эмбеддинги + при provider=openai + генерация изображений) ---
OPENAI_API_KEY=

# --- DeepSeek (основной провайдер генерации текста, ОБЯЗАТЕЛЕН) ---
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# --- KIE (генерация изображений / текста, нужен только при provider="kie") ---
KIE_API_KEY=
KIE_API_BASE=https://api.kie.ai/v1
KIE_API_HOST=https://api.kie.ai

# --- Qdrant (база знаний / RAG) ---
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# --- SearXNG (поиск для Scout) ---
# SEARXNG_URL=http://localhost:8082

# ====== ID моделей (единый реестр в registry.py: MODELS) ======
# Раскомментируйте и впишите РЕАЛЬНЫЕ ID, если дефолтные неверны.
# Pipeline.run() делает preflight и упадёт со списком недоступных моделей.
# Вероятно правильные для DeepSeek: deepseek-reasoner (вместо v4-pro), deepseek-chat (вместо v4-flash).
# MODEL_DEEPSEEK_PRO=deepseek-reasoner
# MODEL_DEEPSEEK_FLASH=deepseek-chat
# MODEL_OPENAI_TEXT=gpt-4o
# MODEL_KIE_TEXT=claude-4.7
# MODEL_OPENAI_IMAGE_PRIMARY=gpt-image-2
# MODEL_OPENAI_IMAGE_FALLBACK=dall-e-3
